{
	"name": "directus-extension-quality-measurements-interface",
	"description": "Directus interface extension for inline quality measurement entry driven by a configurable metric skeleton",
	"icon": "biotech",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-interface"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "interface",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0 || ^11.0.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.0",
		"typescript": "^6.0.2",
		"vue": "^3.5.30"
	}
}
