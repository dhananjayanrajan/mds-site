{
  "name": "directus-extension-expandable-blocks",
  "version": "1.3.5",
  "description": "M2A interface with inline expandable editing for Directus. Provides reusable ItemSelector components for other extensions.",
  "author": "Christopher Schwarz <christopher@neugebauerschwarz.com>",
  "license": "MIT",
  "homepage": "https://github.com/smartlabsAT/directus-expandable-blocks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smartlabsAT/directus-expandable-blocks.git"
  },
  "bugs": {
    "url": "https://github.com/smartlabsAT/directus-expandable-blocks/issues"
  },
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-interface",
    "m2a",
    "blocks",
    "cms",
    "reusable-components",
    "item-selector",
    "shared-components"
  ],
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "shared": [
        "./dist/shared/index.d.ts"
      ]
    }
  },
  "engines": {
    "node": ">=16"
  },
  "directus:extension": {
    "type": "interface",
    "path": "dist/index.js",
    "name": "expandable-blocks",
    "source": "src/index.ts",
    "host": "^11.0.0",
    "icon": "dashboard_customize"
  },
  "scripts": {
    "build": "directus-extension build && node build-types.js",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "type-check": "tsc --noEmit && echo '✅ TypeScript type-check passed!'",
    "type-check:strict": "tsc --noEmit --project config/tsconfig.strict.json",
    "type-check:quality": "tsc --noEmit --project config/tsconfig.quality.json",
    "test": "vitest --config config/vitest.config.ts",
    "test:ui": "vitest --ui --config config/vitest.config.ts",
    "test:coverage": "vitest --coverage --config config/vitest.config.ts",
    "prepublishOnly": "npm run type-check && npm run build && npm run test -- --run",
    "version": "npm run build && git add dist/",
    "postversion": "git push && git push --tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "lint": "eslint . -c config/eslint.config.js",
    "lint:fix": "eslint . -c config/eslint.config.js --fix",
    "qodana": "./config/scripts/qodana-local.sh",
    "test:e2e": "playwright test --config config/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config config/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug --config config/playwright.config.ts",
    "test:e2e:headed": "playwright test --headed --config config/playwright.config.ts",
    "demo:record": "playwright test --config=config/playwright-demo.config.ts",
    "demo:product": "playwright test --config=config/playwright-demo.config.ts test/demo/product-demo.spec.ts --grep=\"Complete Product Demonstration\"",
    "demo:highlights": "DEMO_HEADLESS=true playwright test --config=config/playwright-demo.config.ts --grep=\"Feature Highlights\"",
    "clean:outputs": "./config/scripts/cleanup-outputs.sh",
    "precommit": "npm run type-check && npm run lint"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.1.4",
    "@directus/types": "^15.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.9.0",
    "sass": "^1.98.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "lodash-es": "^4.18.1",
    "vuedraggable": "^4.1.0"
  }
}
