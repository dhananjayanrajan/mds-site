{
  "name": "@nialto-services/directus-extension-url-helpers",
  "description": "Generate permalinks and slugs from other fields using templates.",
  "version": "1.1.2",
  "license": "GPL-3.0-or-later",
  "icon": "link",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-interface",
    "link",
    "permalink",
    "slug",
    "url"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NialtoServices/directus-extension-url-helpers"
  },
  "author": {
    "name": "Nialto Services",
    "email": "support@nialtoservices.co.uk",
    "url": "https://nialtoservices.co.uk/"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "directus:extension": {
    "type": "bundle",
    "host": "^10.10.0",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "interface",
        "name": "url-helpers-permalink",
        "source": "src/url-helpers-permalink/index.ts"
      },
      {
        "type": "interface",
        "name": "url-helpers-slug",
        "source": "src/url-helpers-slug/index.ts"
      }
    ]
  },
  "scripts": {
    "add": "directus-extension add",
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "validate": "directus-extension validate",
    "validate:types": "tsc --noEmit",
    "lint:styles": "stylelint 'src/**/*.{vue,css,scss}'",
    "format:styles": "stylelint 'src/**/*.{vue,css,scss}' --fix",
    "format:code": "prettier --write 'src/**/*.{ts,vue,json,md}'"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.0.5",
    "@sindresorhus/slugify": "^3.0.0",
    "micromustache": "^8.0.3",
    "prettier": "^3.8.1",
    "stylelint": "^17.0.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-order": "^7.0.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.27",
    "vue-i18n": "^11.2.8"
  }
}
